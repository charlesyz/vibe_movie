{
  "compilerOptions": {
    "composite": true,
    "module": "ES2022",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "out",
    "skipLibCheck": true,
    "strict": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["electron/**/*", "electron.vite.config.ts"]
}
